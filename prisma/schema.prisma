// No Verde — Otimizador de Campanhas Meta Ads
// Prisma schema (SQLite) — multi-tenant (cada usuário só vê seus dados)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns Campaign[]
  products  Product[]
}

// Lista de emails de compradores autorizados a se cadastrar.
// Só quem está nesta lista (e com Gmail) consegue criar conta.
model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  note      String?  // anotação: nome do cliente, data da compra, etc.
  used      Boolean  @default(false) // true quando já criou a conta
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Funil de ofertas (valores em R$)
  price          Float @default(0) // Ticket principal (preço do produto)
  orderBumpName  String?
  orderBumpPrice Float  @default(0) // Order bump (oferta adicional no checkout)
  upsellName     String?
  upsellPrice    Float  @default(0) // Upsell (oferta logo após a compra)
  downsellName   String?
  downsellPrice  Float  @default(0) // Downsell (oferta mais barata se recusar o upsell)

  // Extra
  url String? // página de vendas

  campaigns Campaign[]
}

model Campaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Data do relatório (a que data os dados se referem) — para filtros por período
  reportDate DateTime @default(now())

  // Vínculo com produto (opcional)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Identificação
  name     String // Campanha
  delivery String @default("Ativa") // Veiculação (Ativa, Pausada, Em análise, Rejeitada)
  actions  String @default("") // Ações (objetivo)

  // Orçamento
  budget Float @default(0) // Orçamento
  spent  Float @default(0) // Valor usado

  // Engajamento
  ctr Float @default(0) // CTR (todos) — percentual

  // Finalizações de compra iniciadas
  checkoutInitiated         Float @default(0) // Finalizações de compra iniciadas
  checkoutInitiatedApp      Float @default(0) // no app para celular
  checkoutInitiatedSite     Float @default(0) // no site
  checkoutInitiatedOffline  Float @default(0) // offline
  checkoutInitiatedMeta     Float @default(0) // na Meta

  // Visualizações da página de destino
  landingPageViews    Float @default(0) // Visualizações da página de destino
  landingPageViewsApp Float @default(0) // do app
  landingPageViewsSite Float @default(0) // do site

  // Compras
  purchases        Float @default(0) // Compras
  purchasesApp     Float @default(0) // no app
  purchasesSite    Float @default(0) // no site
  purchasesOffline Float @default(0) // offline
  purchasesMeta    Float @default(0) // na Meta

  // Custos
  costPerLandingPageView  Float @default(0) // Custo por visualização da página de destino
  costPerCheckoutInitiated Float @default(0) // Custo por finalização de compra iniciada
  costPerPurchase         Float @default(0) // Custo por compra

  // Valor de conversão da compra
  purchaseConversionValue     Float @default(0) // Valor de conversão da compra
  purchaseConversionValueApp  Float @default(0) // no app
  purchaseConversionValueSite Float @default(0) // no site
  purchaseConversionValueOffline Float @default(0) // offline
  purchaseConversionValueMeta Float @default(0) // na Meta

  // ROAS
  roasPurchases     Float @default(0) // ROAS das compras
  roasPurchasesSite Float @default(0) // ROAS das compras no site
  roasPurchasesApp  Float @default(0) // ROAS das compras no app

  // Métrica central do SaaS
  granaNoBolso Float @default(0) // Valor de conversão da compra - Valor usado (lucro líquido pós-ads)

  @@index([userId, reportDate])
}
